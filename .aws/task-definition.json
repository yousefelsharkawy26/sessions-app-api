{
    "family": "sessions-api-task",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::434676049576:role/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "sessions-api-container",
            "image": "nginx",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp"
                }
            ]
        }
    ]
}